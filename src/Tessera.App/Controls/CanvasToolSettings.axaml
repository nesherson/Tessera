<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Tessera.App.Controls.CanvasToolSettings"
             xmlns:controls="clr-namespace:Tessera.App.Controls"
             xmlns:models="clr-namespace:Tessera.App.Models">
    <UserControl.Styles>
        <Style Selector="Button.ShapeButton">
            <Setter Property="Background" Value="#f1f2f4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="6, 8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#E5E7EB" />
            </Style>
        </Style>

        <Style Selector="Slider.OpacitySlider">
            <Setter Property="Minimum" Value="0.1" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="ToolTip.Tip" Value="Opacity" />
        </Style>
    </UserControl.Styles>
    <Border
        Background="White"
        BorderBrush="#E5E7EB"
        BorderThickness="1"
        CornerRadius="5"
        BoxShadow="0 1 3 0 #10000000"
        Width="134"
        Padding="4">
        <Grid RowDefinitions="Auto, *">
            <StackPanel Spacing="2">
                <ListBox
                    Classes="ToolListBox ColorsListBox"
                    ItemsSource="{Binding AvailableColors, RelativeSource={RelativeSource AncestorType=controls:CanvasToolSettings}}"
                    SelectedItem="{Binding Properties.StrokeColor, RelativeSource={RelativeSource AncestorType=controls:CanvasToolSettings}}" />
                <Slider
                    Classes="OpacitySlider"
                    Value="{Binding Properties.Opacity, RelativeSource={RelativeSource AncestorType=controls:CanvasToolSettings}}" />
                <ListBox
                    x:DataType="models:ShapeSize"
                    Classes="ToolListBox SizeListBox"
                    ItemsSource="{Binding AvailableSizes, RelativeSource={RelativeSource AncestorType=controls:CanvasToolSettings}}"
                    SelectedValue="{Binding Properties.StrokeThickness, RelativeSource={RelativeSource AncestorType=controls:CanvasToolSettings}}"
                    SelectedValueBinding="{Binding Thickness}" />
                <ListBox
                    x:DataType="models:ToolListItem"
                    Classes="ToolListBox TypeListBox"
                    ItemsSource="{Binding AvailableStrokeTypes, RelativeSource={RelativeSource AncestorType=controls:CanvasToolSettings}}"
                    SelectedValue="{Binding Properties.StrokeType, RelativeSource={RelativeSource AncestorType=controls:CanvasToolSettings}}"
                    SelectedValueBinding="{Binding TypeValue}" />
                <ListBox
                    x:DataType="models:ToolListItem"
                    Classes="ToolListBox TypeListBox"
                    ItemsSource="{Binding AvailableFillTypes, RelativeSource={RelativeSource AncestorType=controls:CanvasToolSettings}}"
                    SelectedValue="{Binding Properties.FillType, RelativeSource={RelativeSource AncestorType=controls:CanvasToolSettings}}"
                    SelectedValueBinding="{Binding TypeValue}" />
                <Button
                    Name="ShapeButton"
                    Classes="ShapeButton"
                    Command="{Binding OpenShapePopupCommand, RelativeSource={RelativeSource AncestorType=controls:CanvasToolSettings}}">
                    <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                        <TextBlock Text="Shape"
                                   VerticalAlignment="Center" />
                        <Svg Grid.Column="1"
                             Path="{Binding Path=SelectedShapeType.IconPath, RelativeSource={RelativeSource AncestorType=controls:CanvasToolSettings}}"
                             Width="14"
                             VerticalAlignment="Center" />
                    </Grid>
                </Button>
                <Popup
                    IsOpen="{Binding IsShapePopupOpen, RelativeSource={RelativeSource AncestorType=controls:CanvasToolSettings}, Mode=TwoWay}"
                    Placement="Left"
                    HorizontalOffset="-10"
                    PlacementTarget="{Binding #ShapeButton}"
                    IsLightDismissEnabled="True">
                    <Border Background="White"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="5"
                            BoxShadow="0 1 3 0 #10000000"
                            Padding="2"
                            Width="134">
                        <ListBox
                            x:DataType="models:ToolListItem"
                            Classes="ToolListBox TypeListBox"
                            ItemsSource="{Binding $parent[controls:CanvasToolSettings].AvailableShapeTypes}"
                            SelectedValue="{Binding $parent[controls:CanvasToolSettings].SelectedShapeType}"
                            SelectionChanged="SelectingItemsControl_OnSelectionChanged" />
                    </Border>
                </Popup>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>